# Copy this file to .env and fill in real values. Never commit .env itself.

# Required: powers the ADK agents (get free key at aistudio.google.com)
GEMINI_API_KEY=your_gemini_api_key_here

# Required for weather_mcp server (free tier at openweathermap.org/api)
OPENWEATHER_API_KEY=your_openweather_api_key_here

# Geocoding uses OpenStreetMap Nominatim — no key needed

# Used by security/encryption.py — generate with:
# python -c "import secrets; print(secrets.token_hex(32))"
ENCRYPTION_KEY=your_encryption_key_here
